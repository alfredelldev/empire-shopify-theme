{% comment %}
  Product Secondary Collections (UX-only)
{% endcomment %}

{% if product %}
  {% assign mode = section.settings.mode %}
  {% assign include_raw = section.settings.include_collections | downcase | strip %}
  {% assign exclude_raw = section.settings.exclude_collections | downcase | strip %}

  {% assign include_list = include_raw | split: ',' %}
  {% assign exclude_list = exclude_raw | split: ',' %}

  {% assign style = section.settings.style %}
  {% assign limit = section.settings.limit %}
  {% assign count = 0 %}
  {% assign has_items = false %}

  {%- comment -%}
    Normalize vendor to handle format
    "Brand X" → "brand-x"
  {%- endcomment -%}
  {% assign vendor_handle = product.vendor | handleize %}

  <div class="product-secondary-collections product-section--container product-row--container style-{{ style }}" id="secondary-collections-{{ section.id }}">
    
    {% if section.settings.heading != blank %}
      <div class="psc-heading">{{ section.settings.heading }}</div>
    {% endif %}

    {% if style == 'pill' %}
      <div class="psc-list">
    {% else %}
      <ul class="psc-list">
    {% endif %}

      {% for collection in product.collections %}
        {% assign handle = collection.handle | downcase %}
        {% assign show = false %}

        {%- comment -%}
          Base include/exclude logic
        {%- endcomment -%}
        {% if mode == 'include' %}
          {% if include_raw != blank and include_list contains handle %}
            {% assign show = true %}
          {% endif %}
        {% else %}
          {% assign show = true %}
          {% if exclude_raw != blank and exclude_list contains handle %}
            {% assign show = false %}
          {% endif %}
        {% endif %}

        {%- comment -%}
          NEW: Exclude vendor-matching collection
        {%- endcomment -%}
        {% if section.settings.exclude_vendor and handle == vendor_handle %}
          {% assign show = false %}
        {% endif %}

        {% if show %}
          {% assign has_items = true %}

          {% if limit > 0 and count >= limit %}
            {% break %}
          {% endif %}

          {% assign count = count | plus: 1 %}

          {% if style == 'pill' %}
            <a href="{{ collection.url }}" class="psc-item">
              {{ collection.title }}
            </a>
          {% else %}
            <li class="psc-item">
              <a href="{{ collection.url }}">
                {{ collection.title }}
              </a>
            </li>
          {% endif %}
        {% endif %}
      {% endfor %}

    {% if style == 'pill' %}
      </div>
    {% else %}
      </ul>
    {% endif %}

    {% unless has_items %}
      <style>
        #secondary-collections-{{ section.id }} {
          display: none;
        }
      </style>
    {% endunless %}

  </div>
{% endif %}

<style>
  .product-secondary-collections {
    margin-top: 32px;
  }

  .psc-heading {
    font-size: 14px;
    margin-bottom: 10px;
    font-weight: 600;
    opacity: 0.8;
  }

  /* PILL STYLE */
  .style-pill .psc-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .style-pill .psc-item {
    display: inline-block;
    padding: 6px 12px;
    font-size: 13px;
    text-decoration: none;
    border: 1px solid #1c83c4;
    border-radius: 20px;
    transition: all 0.2s ease;
    color: #1c83c4;
  }

  .style-pill .psc-item:hover {
    border-color: #1c83c4;
    background-color: #1c83c4;
    color: #fff;
  }

  /* LIST STYLE */
  .style-list .psc-list {
    padding-left: 18px;
    margin: 0;
  }

  .style-list .psc-item {
    margin-bottom: 4px;
    font-size: 14px;
  }

  .style-list .psc-item a {
    text-decoration: none;
    color: #1c83c4;
  }

  .style-list .psc-item a:hover {
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Secondary Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More from:"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "pill", "label": "Pill (chips)" },
        { "value": "list", "label": "Simple list (bullets)" }
      ],
      "default": "pill"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Number of items to show",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 0,
      "info": "Set to 0 to show all"
    },
    {
      "type": "checkbox",
      "id": "exclude_vendor",
      "label": "Exclude collections matching product vendor",
      "default": true
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Display Mode",
      "options": [
        {
          "value": "include",
          "label": "Show only included collections"
        },
        {
          "value": "exclude",
          "label": "Show all except excluded"
        }
      ],
      "default": "exclude"
    },
    {
      "type": "text",
      "id": "include_collections",
      "label": "Include Collections (handles, comma separated)",
      "info": "Example: brand-a,luxury-baths,sale"
    },
    {
      "type": "text",
      "id": "exclude_collections",
      "label": "Exclude Collections (handles, comma separated)",
      "info": "Example: frontpage,hidden"
    }
  ],
  "presets": [
    {
      "name": "Secondary Collections"
    }
  ]
}
{% endschema %}